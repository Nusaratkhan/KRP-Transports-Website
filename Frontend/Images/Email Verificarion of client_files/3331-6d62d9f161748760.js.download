"use strict";(self.webpackChunk_N_E=self.webpackChunk_N_E||[]).push([[3331],{43331:function(e,t,a){a.d(t,{Jb:function(){return n.J},zW:function(){return s}});var o=a(46550),i=a(43949),r=a(69427),n=a(45874);let s={"en-US":"en","zh-CN":"cn","zh-TW":"hant","ja-JP":"jp","ko-KR":"ko","th-TH":"th","ru-RU":"ru","hi-IN":"hi","fr-FR":"fr","es-ES":"es","pt-PT":"pt"},_=Object.keys(n.J).find(e=>window.location.pathname.includes("/".concat(e,"/")));o.ZP.use(r.Z).use(i.Db).init({resources:n.J,fallbackLng:"en",lng:_||"en",load:"languageOnly",detection:{caches:[]}}),o.ZP.on("languageChanged",e=>{let t=Object.keys(s).find(t=>s[t]===e)||e;"undefined"!=typeof document&&(document.documentElement.lang=t)}),t.ZP=o.ZP},45874:function(e,t,a){a.d(t,{J:function(){return r}});var o=JSON.parse('{"home":{"meta":{"title":"在线P图改字,AI一键P图改字神器(无痕/免费) | 图改改","description":"最简单快速的P图改字方式，智能P图神器，轻松编辑/添加/删除图片中的文字,AI一键P图改字，无需学习P图技术，摆脱重型软件依赖。支持图片文字识别、图片添加水印、图片删除水印、添加图章等功能。","keywords":"P图,P图神器,修改图片文字,p图改字,图片编辑文字,图片删除文字,图片添加文字"},"app_name":"图改改","short_name":"图片改字","slogan":"智能P图改字","slogan2":"智能P图改字","welcome":"欢迎","description":"最简单快速的P图改字方式，AI加持，点击图片中的文字即可修改，无需P图技能与软件。","upload_image":"上传图片","open_image":"打开图片","uploading":"上传中","confirm_open_same_image":"已上传同名图片，是否直接打开？","drafts":"草稿箱","common_questions":"常见问题","feedback":"反馈","copyright":"保留所有权利, 图改改\xae","eg_signature":"示例-签名","eg_stamp":"示例-图章","eg_a4":"示例-A4","eg_screenshot":"示例-截图","eg_emoji":"示例-表情包","eg_information":"示例-海报","eg_ai":"示例-AI改字","eg_commic":"示例-漫画","about":"关于","contact_us":"联系我们","about_detail":"图改改是一个专注于智能图片文字修改的在线工具。我们的使命是打破专业图像处理的技术门槛。通过先进的 AI 技术，让用户无需掌握 Photoshop 等复杂软件，即可轻松实现图片文字的修改、擦除与替换。\\n我们提供强大且丰富的编辑功能与逼真的视觉特效。除了精准的文字识别，图改改还支持光影融合、透视矫正、风格迁移等高级特效，确保修改后的文字与原图背景完美融合，毫无违和感。\\n我们推崇“极简主义”的操作体验，简单而快捷。无需繁琐的图层操作，只需点击、输入、保存三步，即可在几秒钟内完成专业级的图片修改，让复杂的修图工作变得像打字一样简单。\\n我们高度重视您的数据隐私与安全。图改改承诺绝不收集您的照片、设备信息或地理位置用于广告投放或数据转卖。您的原图与编辑后的图片均会在服务器上定期自动彻底清除（未登录用户 3 天，登录用户 30 天），让您用得放心。\\n我们致力于提供版权无忧的创作环境。平台分发的所有字体及您通过图改改生产的任何内容，均支持免费商用。无论是个人创作还是商业项目，您都无需担忧版权隐患，专注于创意本身。\\n我们追求极致的用户体验与跨平台便利性。无论是在电脑还是手机上，您都能获得流畅、高效的操作体验。我们不断倾听用户反馈，持续优化 AI 模型与交互细节，只为让每一次“改图”都变得简单而美好。","language":"语言","login":"登录","tutorial":"使用手册","insufficient_tokens":"电量不足","ask_charge":"电量不足，是否充电？","charge":"充电","my_bill":"用量","none":"无","support_formats":"图片格式支持","before":"修改前","after":"修改后","drag_and_drop_images_here":"拖拽图片到这里 或","engine":"AI模型","engine_default":"默认","engine_en":"英语识别器","engine_jp":"日语识别器","engine_ko":"韩语识别器","engine_th":"泰语识别器","engine_ru":"俄语识别器","engine_la":"拉丁语识别器","engine_hi":"印地语识别器","engine_cn":"中文识别器","engine_other":"其他","try_one_of_these":"没有图片？试试这些:","how_to_edit_text_in_image":"如何修改图片中的文字？","step1":"上传","step1_detail":"选择你想要编辑其中文字的图片，上传到图改改，进入图片文字编辑器。","step2":"编辑文字","step2_detail":"点击你图片中你想修改的文字，然后修改为你想要的新文字。\\n根据不同情况，你也可以调整文字的字体、颜色、大小、位置。","step3":"下载","step3_detail":"当你修改完要修改的文字，点击右上角的”下载“按钮，即可保存新图片到本地。","privacy_first":"数据安全","privacy_first_detail":"我们的服务器只为登录用户保存图片30天，未登录用户保存1天，逾期彻底清除。","easy_to_use":"简单","easy_to_use_detail":"点击图片中的文字即可直接修改文字。","ai_powered":"AI驱动","ai_powered_detail":"使用AI格式化图片中的文字，让你可以直接修改图片中的文字。","seo_completeness_title":"AI改字","seo_completeness_detail":"支持对话指令改图，基于新一代 AI“语义理解 + 背景智能修复 + 风格迁移” 一体方案，自动完整执行全流程，无需手动框选、手动用消除工具抹掉旧文字，再手动打字、手动调字体颜色位置。","seo_ocr_title":"高精度OCR识别","seo_ocr_detail":"支持识别图片中所有语言的文字。即使是倾斜、弯曲、小字、复杂背景或中英混排，也能精准识别，还原文字几何特征。","seo_bg_title":"背景无痕复原","seo_bg_detail":"文字修改时自动补全背景，无重影、白边或色块，完美还原木纹、布料、光影等复杂纹理。","seo_font_title":"风格完美复刻","seo_font_detail":"AI自动分析原图，精准匹配字体、颜色、粗细、透视、阴影及光泽，让修改痕迹隐形。","seo_font_match_title":"AI匹配字体","seo_font_match_detail":"支持AI识别图片中的字体的功能，提供海量字体使用。","seo_quality_title":"图片编辑功能强大","seo_quality_detail":"除了编辑文字还有其他图片编辑功能，如添加滤镜、素材、艺术字等。支持高清大图处理与导出，保留原图画质细节。","seo_usability_title":"极简操作体验","seo_usability_detail":"网页/APP双端流畅运行，操作直观，无需学习。省去了“涂抹 -> 识别 -> 选字体 -> 对齐”的繁琐步骤，“输入即所得”。","seo_cost_title":"超高性价比","seo_cost_detail":"基本功能免费，高级功能提供充足的免费额度试用，套餐价格透明合理，无隐形消费陷阱。","seo_privacy_title":"隐私与安全","seo_privacy_detail":"不会有收集用户照片、设备信息甚至地理位置的行为，用于精准广告投放或数据转卖等任何地方。编辑的图片会在3天(登录用户30天)后被自动清除。","seo_commercial_title":"免费商用","seo_commercial_detail":"平台分发的字体和生产的任何内容都是免费商用，无需担忧版权隐患。","works_on_web_and_mobile":"电脑/手机","works_on_web_and_mobile_detail":"你可以通过电脑或手机端，随时随地的访问图改改。","faq":"常见问题","recommended_articles":"文章教程","example":"例子","image_text_editor":"图片文字编辑器","not_browser_language":"当前语言非浏览器语言。","features":"功能","user_agreement":"用户协议","privacy_policy":"隐私协议","frequently_asked_questions":"常见问题","contact_support":"联系客服","help":"帮助","parameter_access_and_embed":"传参/嵌入"},"editor":{"mark_tool":"标注工具","mark_tool_tooltip":"可以标记区域来告诉AI要修改的区域，比如\'删除红色区域内容\'","open":"打开","close":"关闭","meta":{"title":"AI图文编辑器-图改改","description":"","keywords":""},"title":"AI图文编辑器","description":"最简单快速的P图改字方式，AI加持轻松修改图片中的文字，点击图片中的文字即可修改，无需P图技能与软件。","effect":"滤镜","stamp":"图章","removement":"消除","removements":"消除效果","information":"信息","wordart":"艺术字","none":"无","gray":"灰度","saturation":"饱和度","black_white":"黑白","light":"亮度","noise":"噪点","mosaic":"马赛克","blur":"模糊","spread":"强度","sharpen":"锐化","choose_image":"选择图片","reset":"重置","export":"导出","add":"添加","itext_placeholder_or":"点击图中文字进行编辑 或","itext_placeholder":"点击图中文字进行编辑","itext_placeholder_ai":"文本框区域将被重绘为新文字","font":"字体","preset":"预设","save_preset":"保存预设","enter_preset_name":"请输入预设名","erase_image":"原文字","style":"样式","prompt":"提示语","position":"位置","transform":"变换","no_text_selected":"未选中文字","download":"下载","color":"颜色","color_fill":"颜色填充","BG_color":"背景色","size":"大小","weight":"粗细","stroke":"描边","span":"字距","opacity":"透明度","rotation":"旋转","bold":"粗体","italic":"斜体","underline":"下划线","through":"删除线","adjust_params":"调整参数","input_value":"输入数值","range":"范围：{{min}} ~ {{max}}","loading":"加载中","processing":"处理中","model_downloading":"加载中","ai_generating":"正在生成...","slow_generating":"正在生成，可能需要约1分钟","recognize_text":"识别文字","upload_font":"上传字体","click_to_generate":"点击生成","long_press_to_save":"或 长按保存","attribute":"属性","scaleX":"水平缩放","scaleY":"垂直缩放","skew_x":"倾斜","delete":"删除","go_back":"返回","text":"文字","text_effect":"文字特效","text_