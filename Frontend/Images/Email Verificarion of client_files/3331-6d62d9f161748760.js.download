ंप्यूट अंक का उपभोग करेंगी। उदाहरण के लिए, \'वॉटरमार्क हटाएं\' और \'AI हटाना\' प्रत्येक के लिए 5 कंप्यूट अंक की आवश्यकता होती है। इसलिए, 100 कंप्यूट अंक 20 छवियों से वॉटरमार्क को हटाने या 20 बार AI हटाने के लिए उपयोग किए जा सकते हैं।\\nजो सुविधाएँ कंप्यूट अंक का उपभोग करती हैं, वे कंप्यूट अंक आइकन और आवश्यक कंप्यूट अंकों के साथ प्रदर्शित होंगी, जबकि अन्य सुविधाएँ मुफ्त में उपयोग करने के लिए उपलब्ध हैं।","wan_to_remove_ads":"क्या आप विज्ञापन हटाना चाहते हैं?","billed_monthly":"एक माह","billed_yearly":"एक वर्ष","discount":"बचत","expires":"समाप्त होता है","paying_meas":"भुगतान करने से तुम समझ जाते हो कि तुम सहमत हो"},"remove_watermark":{"meta":{"title":"छवि से वॉटरमार्क हटाएं मुफ्त में ऑनलाइन (AI-सक्षम)","description":"तस्वीरों से वॉटरमार्क हटाने का सबसे सरल और तेज़ तरीका; छवियों से पाठ जोड़ने या हटाने का समर्थन करता है, AI द्वारा संचालित। चित्र में पाठ को संशोधित करने के लिए क्लिक करें, कोई फोटो संपादन कौशल या सॉफ़्टवेयर की आवश्यकता नहीं है।","keywords":"वॉटरमार्क हटाने वाला, छवि वॉटरमार्क हटाना, छवि से पाठ हटाना"},"short_name":"वॉटरमार्क हटाने वाला","link":"ऑनलाइन वॉटरमार्क हटाने वाला","slogan":"ऑनलाइन छवि से वॉटरमार्क हटाएं","slogan2":"छवि से वॉटरमार्क और पाठ हटाने का सबसे सरल और तेज़ तरीका। AI द्वारा संचालित, कोई फोटो संपादन कौशल या सॉफ़्टवेयर की आवश्यकता नहीं।","showcase":"प्रदर्शनी","sticker.png":"स्टिकर हटाना","date.png":"तारीख वॉटरमार्क हटाना","brand-logo.png":"ब्रांड वॉटरमार्क हटाना","step_title":"छवि से वॉटरमार्क कैसे हटाएं?"},"scanner":{"meta":{"title":"फोटो को स्कैन किए गए दस्तावेज़ में बदलें - ऑनलाइन फोटो स्कैनर (आसान और मुफ्त)","description":"ऑनलाइन फोटो स्कैनर, फोटो को स्कैन किए गए दस्तावेज़ और PDF प्रतियों में बदलें, रोटेशन, पहचान, पाठ संशोधन, हस्ताक्षर/स्टाम्प जोड़ने और विभिन्न प्रभावों का समर्थन करें, प्रिंटर/स्कैनर की आवश्यकता नहीं।","keywords":"फोटो स्कैनर, फोटो को स्कैन करें"},"short_name":"फोटो स्कैनर","slogan":"ऑनलाइन फोटो को स्कैन किए गए दस्तावेज़ में बदलें","description":"ऑनलाइन फोटो स्कैनर, फोटो को स्कैन किए गए दस्तावेज़ और PDF प्रतियों में बदलें, प्रिंटर/स्कैनर की आवश्यकता नहीं। आसान और मुफ्त।","before":"स्कैन से पहले","after":"स्कैन के बाद","effect_better":"बेहतर","effect_bnw":"काला और सफेद","effect_effects":"प्रभाव","rotate":"घुमाएँ","edit_text":"पाठ ठीक करें","add_sign":"हस्ताक्षर/स्टाम्प","step_title":"फोटो को स्कैन किए गए दस्तावेज़ में कैसे बदलें?","formats":"एक प्रारूप चुनें","upload":"अपलोड करें","upload_desc":"अपलोड बटन पर क्लिक करें, लक्षित छवि का चयन करें, या इसे अपलोड क्षेत्र में खींचें;","adjust_points":"बिंदुओं को समायोजित करें","adjust_points_desc":"अपलोड की गई छवि \'स्कैन से पहले\' दृश्य पर चार वृत्तों के साथ एक चौकोण में दिखाई देगी, ताकि आप उस क्षेत्र को चिह्नित कर सकें जिसे आप स्कैन किए गए दस्तावेज़ में बदलना चाहते हैं। आपको इन चार बिंदुओं के स्थानों को समायोजित करने की आवश्यकता हो सकती है। एक बार समायोजित करने के बाद, परिवर्तित पूर्वावलोकन स्वचालित रूप से उत्पन्न होगा। आप छवि को घुमाने या प्रभाव जोड़ने जैसी क्रियाएँ भी कर सकते हैं।","download_desc":"परिवर्तन के बाद, आप \'स्कैन के बाद\' दृश्य के शीर्ष दाएं कोने में डाउनलोड बटन पर क्लिक करके निर्यात प्रारूप चुन सकते हैं, PNG और PDF का समर्थन करते हैं;","free":"मुफ्त","free_desc":"पूर्ण रूप से मुफ्त फोटो स्कैनिंग कार्यक्षमता।","easy_to_use_detail":"स्वचालित रूप से पहचानें और परिवर्तित करें, प्रिंटर या स्कैनर की आवश्यकता नहीं।"},"translator":{"meta":{"title":"ऑनलाइन इमेज ट्रांसलेटर - PhoText","description":"AI-प्रेरित इमेज टेक्स्ट ट्रांसलेटर। उन्नत AI तकनीक का उपयोग करके इमेज/फोटो के टेक्स्ट को अन्य भाषाओं में आसानी से अनुवाद करें; 100+ भाषाओं का समर्थन करता है, जिसमें अंग्रेजी, कोरियाई, जापानी, फ्रांसीसी, चीनी और अन्य शामिल हैं; अनुवाद परिणामों को संपादित करने और समायोजित करने की अनुमति देता है; बैच इमेज ट्रांसलेशन का समर्थन करता है; बस एक इमेज अपलोड करें (JPG, PNG, JPEG, WEBP को सपोर्ट करता है) और अनुवादित इमेज प्राप्त करें।","keywords":"इमेज ट्रांसलेट, इमेज पर अनुवाद"},"short_name":"इमेज ट्रांसलेट करें","slogan":"चित्र अनुवादक","description":"AI द्वारा संचालित इमेज अनुवाद अन्य भाषाओं में उच्च सटीकता के साथ और अनुवाद परिणामों को समायोजित करने के लिए समर्थन प्रदान करता है।","showcase":"प्रदर्शन","product.png":"ई-कॉमर्स इमेज ट्रांसलेट","paper.jpg":"फोटो ट्रांसलेट","commic.png":"कॉमिक ट्रांसलेट","translating":"अनुवादित हो रहा है","source_language":"स्रोत भाषा","target_language":"लक्ष्य भाषा"},"font_identifier":{"meta":{"title":"AI फ़ॉन्ट पहचानकर्ता, ऑनलाइन छवियों में फ़ॉन्ट पहचानें - PhoText","description":"छवियों में पाठ के लिए AI-संचालित फ़ॉन्ट पहचानकर्ता। सभी फ़ॉन्ट व्यावसायिक उपयोग के लिए मुफ्त हैं और मुफ्त डाउनलोड करने के लिए उपलब्ध हैं। 100% व्यावसायिक उपयोग के लिए मुफ्त। अंग्रेजी, हिंदी, जापानी, कोरियाई और 20 से अधिक भाषाओं का समर्थन करता है।","keywords":"फ़ॉन्ट पहचानकर्ता, फ़ॉन्ट पहचानें, फ़ॉन्ट खोजें, ऑनलाइन फ़ॉन्ट खोज, छवि पाठ पहचान"},"short_name":"फ़ॉन्ट पहचानकर्ता","slogan":"छवियों से फ़ॉन्ट पहचानें","description":"AI-संचालित फ़ॉन्ट खोजकर्ता। छवियों में फ़ॉन्ट को बुद्धिमानी से पहचानें। सभी फ़ॉन्ट व्यावसायिक उपयोग के लिए मुफ्त हैं और मुफ्त डाउनलोड करने के लिए उपलब्ध हैं।","showcase":"प्रदर्शन","identify":"फ़ॉन्ट पहचानें","recognize_font":"फ़ॉन्ट पहचानें","font_recognize":"फ़ॉन्ट पहचान","find":"खोजें","find_font":"फ़ॉन्ट खोजें","usage":"उपयोग","start_recognizing":"अभी पहचानें","recognizing":"फ़ॉन्ट पहचान रहा है...","similar_fonts":"समान फ़ॉन्ट","similarity":"समानता","undo_combination":"संयोजन पूर्ववत करें","ocr_model":"OCR मॉडल","example":"फ़ॉन्ट पहचान उदाहरण","upload_image":"छवि अपलोड करें","select_text":"पाठ चुनें","click_text_to_identify":"पहचानने के लिए छवि में पाठ पर क्लिक करें","identify_result":"पहचाने गए फ़ॉन्ट","confirm_open_new_image":"क्या आप वापस जाकर नई छवि अपलोड करना चाहते हैं?","style_parameters":"शैली पैरामीटर","text_direction":"पाठ दिशा","text_color":"पाठ रंग","text_size_ratio":"पाठ आकार अनुपात","stroke_width_ratio":"स्ट्रोक चौड़ाई अनुपात","stroke_color":"स्ट्रोक रंग","line_spacing_ratio":"पंक्ति अंतर अनुपात","angle":"कोण","download":"डाउनलोड करें","apply":"लागू करें","commercial_free":"मुफ्त","font_name":"फ़ॉन्ट नाम","font_copyright":"फ़ॉन्ट कॉपीराइट"},"pdf_text_editor":{"m