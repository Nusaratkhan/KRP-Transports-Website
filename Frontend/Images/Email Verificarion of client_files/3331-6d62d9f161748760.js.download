ove_default_watermark_first":"Пожалуйста, сначала удалите водяной знак платформы","paper":"Бумага","template":"Шаблон","intensity":"Интенсивность"},"error":{"title":"\uD83D\uDE35 Ой, возникла проблема!","content":"Уже уведомили администратора, обновите страницу.","Invalid Code":"Неверный код"},"validator":{"can_not_be_empty":"Не может быть пустым","must_be_number":"Должно быть числом","invalid_format":"Неверный формат","must_greater_than_zero":"Должно быть больше нуля","1_2_decimal_places":"1-2 десятичных знака","can_not_exceed_11_digits":"Не может превышать 11 цифр"},"login":{"login":"Войти","tokens":"Токены","topup":"Купить вычислительные очки","bind_email":"Привязать email","reset_password":"Сброс пароля","logout":"Выйти","logout_confirm":"Вы уверены, что хотите выйти?","login_with_sms":"Войти с помощью SMS","login_with_email":"Войти с помощью email","phone_number":"Номер телефона","verification_code":"Код подтверждения","resend":"Отправить снова","get_verification_code":"Получить код","code_has_been_sent":"Код подтверждения отправлен","failed_to_send":"Не удалось отправить","invalid_email_address":"Неверный адрес электронной почты","invalid_username_password":"Неверное имя пользователя или пароль","email_address":"Адрес электронной почты","password":"Пароль","register_login":"Регистрация/Вход","new_password":"Новый пароль","successfully_modified":"Успешно изменено","welcome":"Добро пожаловать в PhoText","advantages":"Вход в один клик, сохранение на нескольких устройствах\\nПростые функции редактирования текста на изображении\\nИнтерфейс, удобный для новичков\\nБезопасная и надежная защита данных\\nПоддержка ПК и смартфонов\\n","successfully_loggedin":"Вы успешно вошли","login_first":"Сначала войдите","account_deletion":"Удаление аккаунта","account_deletion_forever":"Удалить аккаунт навсегда","account_deletion_success":"Аккаунт успешно удалён","account_deletion_confirm":"Вы уверены, что хотите навсегда удалить этот аккаунт? Это действие нельзя отменить.","account_deletion_must_same":"Email должен соответствовать текущему аккаунту"},"dialog":{"ok":"ОК","cancel":"Отмена","connection_failed":"Сервис обновляется, пожалуйста, попробуйте позже."},"cloud":{"upload_image":"Удаление водяного знака","gift":"Подарок от системы","ai_modify_text":"AI сервис генерации","ai_inpaint":"AI сервис генерации","recharge":"Пополнить","exchange_code":"обмен энергии","referral_bonus":"бонус за регистрацию нового пользователя","paid_bonus":"бонус за зарядку нового пользователя","subscription":"Подписка","kontext":"Редактирование изображений с ИИ","subscription_reset":"Подписка истекла"},"shortcuts":{"up_arrow":"Стрелка вверх: Переместить выделенный текст/изображение вверх","down_arrow":"Стрелка вниз: Переместить выделенный текст/изображение вниз","left_arrow":"Стрелка влево: Переместить выделенный текст/изображение влево","right_arrow":"Стрелка вправо: Переместить выделенный текст/изображение вправо","space":"Пробел: Сравнить старое и новое изображение","shift":"Shift: Пропорциональное масштабирование при перетаскивании углов","copy":"Копировать выделенный текст в новое текстовое поле"},"pay":{"credits_purchase":"Купить вычислительные очки","credits_info":"Описание вычислительных очков:","credits_info_details":"Выберите план пополнения:","电量小包":"Базовый пакет","电量中包":"Продвинутый пакет<1>(скидка 20%)</1>","电量大包":"Pro пакет<1>(скидка 50%)</1>","电量大包x5":"Pro пакет x5<1>(скидка 58%)</1>","单次包":"Разовый пакет","including_credits":"Включая очки","expire_desc":"Никогда не истекает","currency_symbol":"$","payment_amount":"Сумма оплаты","unit_name":"Очки","payment_issue_help":"Проблемы с оплатой? Попробуйте <1>оплатить в новом окне</1>","stripe_secure_checkout":"Безопасная оплата","stripe_test_mode":"Тестовый режим","stripe_redirecting":"Переадресация...","stripe_pay_amount":"Оплатить {{amount}}","stripe_subscribe_amount":"Подписаться за {{amount}}","stripe_powered_by":"Безопасная оплата через Stripe.","stripe_powered_by_recurring":"Безопасная рекуррентная оплата через Stripe.","stripe_supported_cards":"Поддерживаются Visa, Mastercard и Amex.","stripe_payment_success":"Оплата успешно завершена.","stripe_payment_incomplete":"Оплата не была завершена.","stripe_checkout_failed":"Не удалось начать оформление оплаты.","stripe_checkout_url_missing":"URL Stripe Checkout не был получен.","stripe_payment_pending":"Platezh poluchen. Vashi Compute Points sinkhroniziruyutsya."},"subscribe":{"subscribe":"Подписаться","renewal":"Продление подписки","subscription":"Подписка","subscribe_to":"Подписаться на PhoText","subscribe_desc":"Описание подписки","subscribe_desc_details":"✓ Удалите все объявления.\\n✓ Получите больше вычислительных баллов, чтобы обрабатывать больше изображений.","points_desc_details":"1. Баллы — это цифровой продукт, предоставляемый PhoText, и во время использования PhoText некоторые функции потребляют вычислительные баллы.\\n","plan_free":"Бесплатный план","plan_basic":"Базовый план","plan_standard":"Стандартный план","plan_premium":"Премиум план","plan_single":"План покупки одного изображения","points":"Баллы","including_points":"Включая баллы","expire_desc":"Никогда не истекает","currency_symbol":"$","payment_amount":"Сумма платежа","unit_name":"Баллы","month":"Месяц","year":"Год","whats_point":"Что такое вычислительные баллы?","whats_point_details":"Во время использования PhoText некоторые функции потребляют вычислительные баллы. Например, для удаления водяного знака и удаления ИИ требуется по 5 вычислительных баллов. Таким образом, с 100 вычислительными баллами вы можете удалить водяной знак с 20 изображений или использовать удаление ИИ 20 раз.\\nФункции, которые потребляют вычислительные баллы, отображают значок вычислительных баллов и необходимое количество баллов, в то время как другие функции можно использовать бесплатно.","wan_to_remove_ads":"Хотите удалить рекламу?","billed_monthly":"1 месяц","billed_yearly":"1 год","discount":"Скидка","paying_meas":"Оплата означает, что вы соглашаетесь с"},"remove_watermark":{"meta":{"title":"Удаление водяных знаков с изображений, бесплатно онлайн - PhoText","description":"Самый простой и быстрый способ удаления водяных знаков с изображений. Поддержка добавления и удаления текста на изображении, с помощью AI можно кликнуть по тексту для его исправления и удаления.","keywords":"удаление водяных знаков с изображений, удаление текста с изображений"},"link":"Удаление водяных знаков","slogan":"Онлайн удаление водяных знаков, AI удаление","slogan2":"Удаление водяных знаков и текста на изображении самым простым и быстрым способом. Поддержка AI для исправления и удаления текста.","showcase":"Показать эффекты","sticker.png":"Удаление наклеек","date.png":"Удаление водяных знаков даты","brand-logo.png":"Удаление водяных знаков бренда"},"scanner":{"meta":{"title":"Конвертировать фото в отсканированный документ - Онлайн-сканер (Просто и Бесплатно)","description":"Онлайн-сканер, конвертация фото в отсканированный документ и PDF, поддержка вращения, распознавания, редактирования текста, добавления подписей/штампов, различных эффектов, без необходимости в принтере/сканере.","keywords":"сканер фото, фото в скан"},"short_name":"Фото в скан","slogan":"Конвертируйте фото в отсканированный документ онлайн","description":"Онлайн-сканер, конвертация фото в отсканированный документ и PDF онлайн, без необходимости в принтере/сканере. Просто и бесплатно.","before":"До сканирования","after":"После сканирования","effect_better":"Улучшить","effect_bnw":"Черно-белое","effect_effects":"Эффекты","rotate":"Вращать","edit_text":"Редактировать текст","add_sign":"Подпись/Штамп","step_title":"Как конвертировать фото в отсканированный документ?","formats":"Выберите формат","upload":"Загрузить","upload_desc":"Нажмите кнопку загрузки, выберите целевое изображение или перетащите его в область загрузки;","adjust_points":"Настроить точки","adjust_points_desc":"Загруженное изображение появится в представлении \'До сканирования\' с четырьмя кругами, образующими четырехугольник, чтобы обозначить область, которую необходимо конвертировать в отсканированный документ. Возможно, вам потребуется настроить расположение этих четырех точек. После настройки автоматически создается предварительный просмотр конверсии. Также можно выполнять операции, такие как вращение изображения или добавление эффектов.","download_desc":"После конверсии вы можете нажать кнопку загрузки в правом верхнем углу представления \'После сканирования\', чтобы выбрать формат экспорта, поддерживаются PNG и PDF;","free":"Бесплатно","free_desc":"Полностью бесплатная функция сканирования фото.","easy_to_use_detail":"Автоматическое обнаружение и преобразование, не требуется принтер или сканер."},"translator":{"meta":{"title":"Онлайн Переводчик Изображений - PhoText","description":"Переводчик текста на изображениях с использованием ИИ. Легко переводите текст на изображениях/фотографии на другие языки с использованием передовой технологии ИИ; поддерживает более 100 языков, включая английский, корейский, японский, французский, китайский и другие; позволяет редактировать и настраивать результаты перевода; поддерживает пакетный перевод изображений; просто загрузите изображение (поддерживаются JPG, PNG, JPEG, WEBP) и получите переведенное изображение.","keywords":"Перевод изображений, перевод на изображении"},"short_name":"Перевести изображение","slogan":"Переводчик изображений","description":"Перевод изображений с использованием ИИ на другие языки с высокой точностью и поддержкой настройки результатов перевода.","showcase":"Демонстрация","product.png":"Перевод изображений для электронной коммерции","paper.jpg":"Перевод фотографий","commic.png":"Перевод комиксов","translating":"Переводится","source_language":"Исходный язык","target_language":"Целевой язык"},"font_identifier":{"meta":{"title":"AI Распознавание шрифтов, определите шрифты в изображениях онлайн - PhoText","description":"AI-подобная система распознавания шрифтов в тексте изображений. Все шрифты бесплатны для коммерческого использования и могут быть скачаны бесплатно. 100% свободно для коммерческого использования. Поддерживает английский, китайский, японский, корейский и более 20 языков.","keywords":"Распознавание шрифтов, AI распознавание шрифтов, определение шрифта, распознавание шрифта в изображении, онлайн распознавание шрифтов, распознавание текста в изображении"},"short_name":"Распознавание шрифтов","slogan":"Определите шрифты из изображений","description":"Поиск шрифтов на основе ИИ. Интеллектуально распознает шрифты в изображениях. Все шрифты бесплатны для коммерческого использования и могут быть скачаны бесплатно.","showcase":"Примеры","identify":"Определить шрифт","recognize_font":"Определить шрифт","font_recognize":"Распознавание шрифта","find":"Найти","find_font":"Найти шрифт","usage":"Использование","start_recognizing":"Определить сейчас","recognizing":"Распознавание шрифтов...","similar_fonts":"Похожие шрифты","similarity":"Сходство","undo_combination":"Отменить объединение","ocr_model":"OCR модель","example":"Пример распознавания шрифта","upload_image":"Загрузить изображение","select_text":"Выбрать текст","click_text_to_identify":"Щелкните на тексте в изображении, чтобы определить","identify_result":"Определенные шрифты","confirm_open_new_image":"Подтверждаете, что хотите вернуться и загрузить новое изображение?","style_parameters":"Параметры стиля","text_direction":"Направление текста","text_color":"Цвет текста","text_size_ratio":"Соотношение размера текста","stroke_width_ratio":"Соотношение ширины обводки","stroke_color":"Цвет обводки","line_spacing_ratio":"Соотношение интерлиньяжа","angle":"Угол","download":"Скачать","apply":"Применить","commercial_free":"Бесплатно (для коммерческого использования)","font_name":"Название шрифта","font_copyright":"Авторские права на шрифт"},"pdf_text_editor":{"meta":{"title":"Редактор текста PDF - OCR онлайн редактирование текстового содержимого в PDF | PhoText","description":"Профессиональный редактор текста PDF на основе OCR, поддерживающий онлайн редактирование текстового содержимого в PDF документах. Не требует загрузки программного обеспечения, прямое изменение текста PDF, настройка стилей шрифта, цветов и размеров в браузере. Простой и удобный инструмент для редактирования текста PDF.","keywords":"редактор текста PDF,редактирование PDF,изменение текста PDF,онлайн редактор PDF,редактирование текста PDF,изменить текст PDF,редактирование содержимого PDF"},"app_name":"PhoText","short_name":"Редактор текста PDF","slogan":"Редактор текста PDF","description":"Текстовый редактор PDF на основе OCR, поддерживает редактирование текста в отсканированных PDF","drag_and_drop_pdfs_here":"Перетащите PDF сюда или","upload_pdf":"Загрузить PDF","step_title":"Как редактировать текст PDF?"},"ai_image_editor":{"meta":{"title":"AI Редактор Изображений - Бесплатный умный онлайн-редактор","description":"Редактор изображений, использующий технологии искусственного интеллекта (ИИ) для обработки, редактирования или создания визуального контента. В отличие от традиционных редакторов, он значительно сокращает ручные операции и сложные рабочие процессы, позволяя редактировать изображения с помощью простого диалога. Также предоставляет множество интеллектуальных функций, таких как автоматическое распознавание, умная коррекция, умная генерация и заполнение, удаление и замена в один клик, передача художественного стиля, верстка текста и дизайн и т.д.","keywords":"AI редактор изображений, AI фоторедактор, Онлайн редактор изображений"},"app_name":"PhoText","short_name":"AI Редактор Изображений","slogan":"AI Редактор Изображений","description":"Умная ретушь, бесшовное редактирование текста, AI вырезание, AI удаление, замена объектов, перенос стиля, удаление водяных знаков, фото на документы и многое другое - магия у вас под рукой","drag_and_drop_images_here":"Перетащите изображение сюда или","upload_image":"Загрузить изображение","step_title":"Как редактировать изображение с помощью ИИ?"},"kontext":{"ai_image_editing":"PhoText AI","send":"Отправить","me":"Я","target_it":"Выбрать","targeted_it":"Выбрано","please_enter_the_prompt":"Как вы хотите изменить изображение на холсте?","simple_mode":"Простой режим","advanced_mode":"Продвинутая интеллектуальность","simple_mode_desc":"Более быстрая модель ИИ, подходит для простых правок","advanced_mode_desc":"Более интеллектуальное понимание, лучшие результаты редактирования","add_reference_image":"Добавить эталонное изображение","pro_free_trial_tip":"Вы получили бесплатную пробную версию режима \\"Продвинутая интеллектуальность\\", с лучшими результатами.","use_now":"Использовать сейчас"},"pdf_to_images":{"meta":{"title":"PDF в изображения - PhoText","description":"Экспортируйте страницы PDF в качественные PNG прямо в браузере.","keywords":"pdf в изображения,pdf в png,pdf в jpg,извлечь изображения из pdf,онлайн конвертер"},"hero_badge":"Высокое качество \xb7 ZIP автоматически \xb7 Локально","hero_title":"PDF в","hero_title_highlight":"изображения","hero_subtitle":"Экспорт каждой страницы PDF в изображение — удобно для просмотра и обмена.","upload_title":"Загрузите PDF","upload_subtitle":"Поддерживаются многостраничные документы","ready_hint":"READY TO CONVERT","start_export":"Экспортировать изображения","processing_pages":"Processing Pages:","value_1_title":"Retina rendering","value_1_desc":"Rendered at a higher scale for sharp results. Small text stays readable even when zoomed in.","value_2_title":"Auto ZIP package","value_2_desc":"For multi-page PDFs, we bundle all images into a single ZIP for one-click download.","value_3_title":"Share-friendly","value_3_desc":"Изображения легко отправлять и просматривать. Делитесь через Telegram, VK или рабочие чаты.","seo_badge":"Online PDF tool","seo_title":"Convert PDF to images online (HD PNG)","seo_desc":"Turning each PDF page into an image makes it easier to open, preview, annotate, and share. Works on both mobile and desktop, free to use.","seo_card_1_title":"Easier to share & submit","seo_card_1_desc":"Many platforms prefer images for uploads and attachments. Convert PDF pages to images for quick preview and better compatibility.","seo_card_1_bullet_1":"Faster preview","seo_card_1_bullet_2":"Better compatibility","seo_card_2_title":"No watermark, high quality","seo_card_2_desc":"Great for printing, annotations, and archiving. No watermark. No installation or signup. No need to upload your file to a server.","faq_center_title":"FAQ","faq_1_q":"Are the exported images sharp?","faq_1_a":"Yes. We render at a higher scale by default, so PNG outputs stay crisp even when zoomed in.","faq_2_q":"Do you support very long PDFs?","faq_2_a":"Yes. We convert page by page. For best performance, we recommend processing PDFs over 100 pages in smaller batches.","error_alert":"Conversion failed. Please make sure the PDF is not encrypted.","zip_suffix":"_images.zip"},"image_to_pdf":{"meta":{"title":"Изображения в PDF - PhoText","description":"Конвертируйте изображения в PDF прямо в браузере — быстро и безопасно.","keywords":"изображение в pdf,jpg в pdf,png в pdf,объединить в pdf,онлайн конвертер pdf"},"hero_badge":"Конфиденциально \xb7 Без загрузки \xb7 Бесплатно","hero_title":"Изображение в","hero_title_highlight":"PDF","hero_subtitle":"Быстро объединяйте изображения и сохраняйте в PDF.","upload_title":"Выберите файлы или перетащите сюда","upload_subtitle":"JPG, PNG, WEBP, GIF","preview_alt":"Preview","selected_label":"Selected","clear_all":"Очистить","converting":"Конвертация...","convert_button":"В PDF","feature_1_title":"Private conversion","feature_1_desc":"Your images never leave your device. Everything runs locally in your browser to protect your privacy.","feature_2_title":"Instant download","feature_2_desc":"Drop images in, convert in seconds, and download immediately. No uploads and no waiting.","feature_3_title":"Works everywhere","feature_3_desc":"Use it on Mac, Windows, iOS, and Android. Just open the page in a modern browser.","seo_how_title":"How to convert images to PDF online?","seo_how_desc":"Whether you need JPG to PDF, PNG to PDF, or to merge multiple images into one PDF, you can do it directly in your browser—free, high-quality, and privacy-friendly.","seo_how_step_1":"Import or drag your images (JPG, PNG, etc.) into the converter.","seo_how_step_2":"Reorder images or add more files as needed.","seo_how_step_3":"Click “Convert to PDF” and wait a moment.","seo_how_step_4":"Download your high-quality PDF file.","seo_privacy_title":"Quality & privacy","seo_privacy_item_1_strong":"High-quality output:","seo_privacy_item_1_text":"We preserve pixel-level details so your PDF stays crisp when printed or zoomed.","seo_privacy_item_2_strong":"Privacy by design:","seo_privacy_item_2_text":"Unlike cloud converters, processing happens on your device. We do not upload or store your files.","seo_privacy_item_3_strong":"Free to use:","seo_privacy_item_3_text":"No paywalls, no watermarks, and no complicated steps—just upload, convert, and download.","faq_title":"FAQ","faq_1_q":"Can I merge multiple images into one PDF?","faq_1_a":"Yes. Select multiple images and we will combine them into a single PDF in your chosen order.","faq_2_q":"Will the image quality be reduced?","faq_2_a":"No. We keep your image quality as much as possible when wrapping them into a PDF.","faq_3_q":"Can I convert ID photos to PDF?","faq_3_a":"Yes. It is great for ID documents and form submissions that require PDF format.","faq_4_q":"Will the output file be huge?","faq_4_a":"We apply reasonable compression while keeping quality, so the PDF remains easy to share and upload.","merge_failed_alert":"Something went wrong during merging. Please try again.","download_file_prefix":"ImageToPDF"},"footer":{"more_links":{"image_to_pdf":"Изображения в PDF","pdf_to_images":"PDF в изображения","image_remove_text":"Удалить текст с изображения","image_replace_text":"Заменить текст на изображении","poster_change_text":"Редактировать текст на постере","ecommerce_main_image_change_text":"Редактировать текст на главном изображении товара","wechat_alipay_screenshot_change_text":"Редактировать текст на скриншотах Telegram/YooMoney","payment_screenshot_change_text":"Редактировать текст на скриншоте оплаты","watermark_camera_change_text":"Редактировать текст водяного знака","exam_score_screenshot_change_text":"Редактировать текст на скриншоте оценок","leave_note_image_change_text":"Редактировать текст на изображении заявления","certificate_image_change_text":"Редактировать текст на изображении сертификата","call_sms_image_change_text":"Редактировать текст на скриншоте звонков/SMS","ticket_image_change_text":"Редактировать текст на скриншоте билета","fix_text_in_image":"Исправить текст на изображении"}},"common":{"yes":"Да","no":"Нет","more":"Ещё","collapse":"Свернуть"},"call_sms_image_change_text":{"meta":{"title":"Редактировать текст на скриншоте звонков/SMS - PhoText","keywords":"редактировать скриншот звонков, редактировать sms скриншот, изменить текст на скриншоте","description":"Редактируйте текст на скриншотах звонков и SMS с естественным результатом."}},"certificate_image_change_text":{"meta":{"title":"Редактировать текст на изображении сертификата - PhoText","keywords":"редактировать сертификат, изменить текст на сертификате, редактор текста на изображении","description":"Редактируйте текст на изображении сертификата с естественным результатом."}},"ecommerce_main_image_change_text":{"meta":{"title":"Редактировать текст на товарном изображении — PhoText","keywords":"редактировать текст на товарном фото, изменить цену на изображении, ecommerce основное изображение, онлайн редактор товарных изображений","description":"Обновляйте цены, промо-лейблы и продающие тезисы на товарных изображениях, сохраняя стиль. Экспорт в высоком разрешении."}},"exam_score_screenshot_change_text":{"meta":{"title":"Пранк: изменить оценки на скриншоте - PhoText","keywords":"изменить оценки на скриншоте, редактировать текст на скриншоте, изменить текст на изображении, редактор текста на скриншоте","description":"Меняйте оценки/текст на скриншотах с естественным результатом."}},"fix_text_in_image":{"meta":{"title":"Исправить текст на изображении - PhoText","keywords":"исправить текст на изображении, редактировать текст на фото, image text editor","description":"Исправляйте текст на изображениях и скриншотах с естественным результатом и экспортируйте в высоком качестве."}},"image_remove_text":{"meta":{"title":"Удалить текст с изображения онлайн — PhoText","keywords":"удалить текст с изображения, стереть текст, удалить надпись, убрать текст с фото, AI удаление текста","description":"Удаляйте ненужный текст с изображений онлайн. Выберите область с текстом — AI естественно восстановит фон."}},"image_replace_text":{"meta":{"title":"Заменить текст на изображении онлайн — PhoText","keywords":"заменить текст на изображении, редактировать текст на фото, изменить текст на картинке, изменить цену на изображении, онлайн редактор текста","description":"Заменяйте текст на изображении онлайн, сохраняя стиль и макет. Обновляйте заголовки, цены и подписи для постеров, товарных фото и скриншотов."}},"leave_note_image_change_text":{"meta":{"title":"Исправить текст на изображении заявления на отпуск - PhoText","keywords":"исправить текст на изображении, заявление на отпуск, редактировать текст на фото, редактор текста на изображении","description":"Исправляйте текст на изображениях заявления на отпуск и подобных скриншотах с естественным результатом."}},"payment_screenshot_change_text":{"meta":{"title":"Редактировать текст на скриншотах оплаты — PhoText","keywords":"редактировать скриншот оплаты, замазать скриншот, скрыть данные, скриншот для возмещения, скриншот выписки","description":"Редактируйте скриншоты оплаты. Скрывайте чувствительные данные или правьте примечания и экспортируйте чистое изображение в высоком качестве."}},"poster_change_text":{"meta":{"title":"Редактировать текст на постере онлайн — PhoText","keywords":"редактировать текст на постере, изменить текст постера, онлайн редактор постеров, изменить дату место на постере","description":"Редактируйте текст на постерах онлайн: заголовки, подзаголовки, дату/место, цены. Сохраняйте исходный макет и экспортируйте постер в высоком качестве."}},"ticket_image_change_text":{"meta":{"title":"Редактировать текст на скриншоте билета - PhoText","keywords":"редактировать скриншот билета, изменить текст на билете, редактировать маршрут скриншот","description":"Редактируйте текст на скриншотах авиа/жд билетов и маршрутов с естественным результатом."}},"watermark_camera_change_text":{"meta":{"title":"Редактировать адрес/время на водяном знаке - PhoText","keywords":"редактировать водяной знак, изменить адрес на фото, изменить время на фото, редактировать текст водяного знака","description":"Редактируйте адрес, время и текст на водяном знаке на фото."}},"wechat_alipay_screenshot_change_text":{"meta":{"title":"Редактировать текст на скриншотах Telegram/YooMoney — PhoText","keywords":"редактировать текст на скриншоте, telegram скриншот текст, yoomoney скриншот текст, скрыть данные, замазать скриншот","description":"Редактируйте текст на скриншотах Telegram/YooMoney. Заменяйте/закрывайте имена, примечания и чувствительные данные и экспортируйте чистое изображение."}}}')},hi:{name:"हिन्दी",translation:JSON.parse('{"home":{"meta":{"title":"छवि/स्क्रीनशॉट में पाठ ऑनलाइन संपादित करें मुफ्त में (AI-सक्षम) | PhoText","description":"छवि/स्क्रीनशॉट में पाठ संपादित करने का सबसे आसान तरीका, संपादित करने के लिए छवि में किसी भी पाठ पर क्लिक करें, बिना PS कौशल की आवश्यकता, हमारे AI-सक्षम छवि पाठ संपादक के साथ। JPG, PNG, JPEG, WEBP, BMP का समर्थन करें।","keywords":"छवि में पाठ संपादित करें, छवि पाठ संपादक, स्क्रीनशॉट में पाठ संपादित करें, स्क्रीनशॉट पाठ संपादक, स्क्रीनशॉट में पाठ ठीक करें, स्क्रीनशॉट में पाठ बदलें, स्क्रीनशॉट में पाठ प्रतिस्थापित करें, Photext"},"app_name":"PhoText","short_name":"छवि में पाठ संपादित करें","slogan":"ऑनलाइन छवि में पाठ संपादित करें","slogan2":"ऑनलाइन छवि में पाठ संपादित करें","welcome":"स्वागत है","description":"छवि में पाठ संपादित करने का सबसे आसान तरीका, छवि में पाठ पर क्लिक करें और इसे संपादित करें, बिना PS कौशल की आवश्यकता।","upload_image":"छवि अपलोड करें","open_image":"छवि खोलें","uploading":"अपलोड हो रहा है","confirm_open_same_image":"एक ही नाम वाली छवि अपलोड की गई है। क्या आप इसे सीधे खोलना चाहते हैं?","drafts":"ड्राफ्ट","common_questions":"अक्सर पूछे जाने वाले प्रश्न","feedback":"प्रतिक्रिया","copyright":"सर्वाधिकार सुरक्षित, PhoText\xae","eg_signature":"उदाहरण-हस्ताक्षर","eg_stamp":"उदाहरण-हस्ताक्षर","eg_a4":"उदाहरण-डिज़ाइन","eg_screenshot":"उदाहरण-छवि","eg_emoji":"उदाहरण-स्टिकर","eg_information":"उदाहरण-नोटिस","eg_ai":"उदाहरण-AI","eg_commic":"उदाहरण-कॉमिक","about":"हमारे बारे में","contact_us":"संपर्क करें","about_detail":"PhoText एक ऑनलाइन टूल है जो इंटेलिजेंट इमेज टेक्स्ट एडिटिंग के लिए समर्पित है। हमारा मिशन पेशेवर इमेज प्रोसेसिंग की तकनीकी बाधाओं को तोड़ना है। उन्नत AI तकनीक के साथ, उपयोगकर्ता फ़ोटोशॉप जैसे जटिल सॉफ़्टवेयर में महारत हासिल किए बिना छवियों में टेक्स्ट को आसानी से संशोधित, मिटा और बदल सकते हैं।\\nहम शक्तिशाली संपादन सुविधाएँ और यथार्थवादी दृश्य प्रभाव प्रदान करते हैं। सटीक टेक्स्ट पहचान के अलावा, PhoText लाइटिंग फ्यूजन, परिप्रेक्ष्य सुधार और स्टाइल ट्रांसफर जैसे उन्नत प्रभावों का समर्थन करता है, यह सुनिश्चित करते हुए कि संपादित टेक्स्ट मूल पृष्ठभूमि के साथ पूरी तरह से मिश्रित हो जाए बिना किसी विसंगति के।\\nहम एक \\"न्यूनतम\\" उपयोगकर्ता अनुभव की वकालत करते हैं जो सरल और तेज़ हो। किसी भी थकाऊ परत संचालन की आवश्यकता नहीं है—बस क्लिक करें, टाइप करें और सहेजें। सेकंड में पेशेवर-ग्रेड छवि संपादन पूरा करें, जिससे जटिल सुधार टाइपिंग जितना आसान हो जाए।\\nहम आपकी डेटा गोपनीयता और सुरक्षा को प्राथमिकता देते हैं। PhoText विज्ञापन या डेटा पुनर्विक्रय के लिए आपकी तस्वीरें, डिवाइस जानकारी या जियोलोकेशन एकत्र नहीं करने का वादा करता है। आपकी मूल और संपादित छवियां हमारे सर्वर से समय-समय पर स्वचालित रूप से और स्थायी रूप से हटा दी जाती हैं (गैर-लॉग इन उपयोगकर्ताओं के लिए 3 दिन, लॉग इन उपयोगकर्ताओं के लिए 30 दिन), आपकी मन की शांति सुनिश्चित करती हैं।\\nहम कॉपीराइट-मुक्त रचनात्मक वातावरण प्रदान करने के लिए प्रतिबद्ध हैं। प्लेटफ़ॉर्म द्वारा वितरित सभी फोंट और PhoText के माध्यम से आपके द्वारा उत्पादित कोई भी सामग्री व्यावसायिक उपयोग के लिए निःशुल्क है। चाहे व्यक्तिगत निर्माण के लिए हो या व्यावसायिक परियोजनाओं के लिए, आप कॉपीराइट मुद्दों के बारे में चिंता किए बिना रचनात्मकता पर ध्यान केंद्रित कर सकते हैं।\\nहम परम उपयोगकर्ता अनुभव और क्रॉस-प्लेटफ़ॉर्म सुविधा के लिए प्रयास करते हैं। चाहे कंप्यूटर पर हो या मोबाइल फोन पर, आप एक सहज और कुशल संचालन अनुभव का आनंद ले सकते हैं। हम लगातार उपयोगकर्ता प्रतिक्रिया सुनते हैं और एआई मॉडल और इंटरैक्शन विवरणों को लगातार अनुकूलित करते हैं, बस हर \\"संपादन\\" को सरल और अद्भुत बनाने के लिए।","language":"भाषा","login":"लॉग इन करें","tutorial":"ट्यूटोरियल","insufficient_tokens":"अपर्याप्त कंप्यूट अंक","ask_charge":"अपर्याप्त कंप्यूट अंक, क्या आप रिचार्ज करना चाहेंगे?","charge":"रिचार्ज","my_bill":"उपयोग","none":"कोई नहीं","support_formats":"समर्थित प्रारूप","before":"पहले","after":"बाद में","drag_and_drop_images_here":"यहां छवि खींचें और छोड़ें या","engine":"AI मॉडल","engine_default":"डिफ़ॉल्ट","engine_en":"अंग्रेजी पहचानकर्ता","engine_jp":"जापानी पहचानकर्ता","engine_ko":"कोरियाई पहचानकर्ता","engine_th":"थाई पहचानकर्ता","engine_ru":"रूसी पहचानकर्ता","engine_la":"लैटिन पहचानकर्ता","engine_hi":"हिंदी पहचानकर्ता","engine_cn":"चीनी पहचानकर्ता","engine_other":"अन्य भाषा पहचानकर्ता","try_one_of_these":"कोई छवि नहीं? इनमें से एक आज़माएं:","how_to_edit_text_in_image":"छवि में पाठ को कैसे संपादित करें?","step1":"अपलोड करें","step1_detail":"जिस छवि में आप पाठ संपादित करना चाहते हैं उसे चुनें और PhoText पर अपलोड करें।","step2":"पाठ संपादित करें","step2_detail":"अपनी छवि में जिस पाठ को ठीक करना चाहते हैं उस पर क्लिक करें और इसे नए पाठ से बदलें।\\nआप आवश्यकतानुसार पाठ के फॉन्ट, रंग, आकार और स्थिति को भी समायोजित कर सकते हैं।","step3":"डाउनलोड करें","step3_detail":"जब आप पाठ संपादित करना समाप्त कर लें, तो नई छवि को सहेजने के लिए शीर्ष पर \\"डाउनलोड\\" बटन पर क्लिक करें।","privacy_first":"प्राइवेसी पहले","privacy_first_detail":"हमारे सर्वर लॉग इन उपयोगकर्ताओं की छवियों को 30 दिनों तक और बिना लॉग इन उपयोगकर्ताओं की छवियों को 1 दिन तक ही सहेजते हैं; समय सीमा समाप्त होने पर उन्हें स्थायी रूप से हटा दिया जाता है।","easy_to_use":"उपयोग में आसान","easy_to_use_detail":"छवि में पाठ संपादित करने के लिए उस पर क्लिक करें।","ai_powered":"AI-सक्षम","ai_powered_detail":"हम छवि पाठ को संरचित करने के लिए AI का उपयोग करते हैं, जिससे आप हमारे छवि पाठ संपादक का उपयोग करके छवि में पाठ संपादित कर सकें।","seo_completeness_title":"AI पाठ संपादन","seo_completeness_detail":"संवादात्मक छवि संपादन का समर्थन करता है। अगली पीढ़ी के AI समाधान \'अर्थ समझ + स्मार्ट पृष्ठभूमि मरम्मत + शैली हस्तांतरण\' पर आधारित, मैन्युअल चयन, मैन्युअल मिटाने, टाइपिंग, या फ़ॉन्ट/रंग/स्थिति समायोजन के बिना पूरी प्रक्रिया को स्वचालित रूप से निष्पादित करता है।","seo_ocr_title":"उच्च परिशुद्धता OCR पहचान","seo_ocr_detail":"छवियों के भीतर सभी भाषाओं में पाठ पहचान का समर्थन करता है। तिरछे, घुमावदार, छोटे पाठ, जटिल पृष्ठभूमि और मिश्रित लेआउट को सटीक रूप से पहचानता है, ज्यामितीय विशेषताओं को बहाल करता है।","seo_bg_title":"निर्बाध पृष्ठभूमि बहाली","seo_bg_detail":"पाठ संशोधन के दौरान पृष्ठभूमि को स्वचालित रूप से पुनर्स्थापित करता है। कोई भूत, सफेद किनारे या रंग ब्लॉक नहीं। लकड़ी, कपड़े और प्रकाश व्यवस्था जैसी जटिल बनावट को पूरी तरह से बहाल करता है।","seo_font_title":"सही शैली मिलान","seo_font_detail":"AI फ़ॉन्ट, रंग, वजन, परिप्रेक्ष्य, छाया और चमक से मेल खाने के लिए मूल छवि का विश्लेषण करता है, जिससे संपादन अदृश्य हो जाते हैं।","seo_font_match_title":"AI फ़ॉन्ट मिलान","seo_font_match_detail":"छवियों में फ़ॉन्ट्स की AI पहचान का समर्थन करता है, उपयोग के लिए विशाल फ़ॉन्ट लाइब्रेरी प्रदान करता है।","seo_quality_title":"शक्तिशाली छवि संपादन","seo_quality_detail":"पाठ संपादन के अलावा, फिल्टर, स्टिकर और शब्द कला जैसी अन्य छवि संपादन सुविधाएँ प्रदान करता है। उच्च-रिज़ॉल्यूशन छवि प्रसंस्करण और निर्यात का समर्थन करता है, मूल गुणवत्ता को संरक्षित करता है।","seo_usability_title":"उपयोग में आसान","seo_usability_detail":"वेब और ऐप पर सुचारू रूप से चलता है, सहज संचालन, सीखने की कोई आवश्यकता नहीं है। \'smudge -> recognize -> select font -> align\' के थकाऊ चरणों को समाप्त करता है, \'जो आप इनपुट करते हैं वही आपको मिलता है\' अनुभव प्रदान करता है।","seo_cost_title":"उच्च लागत-प्रभावशीलता","seo_cost_detail":"बुनियादी कार्य मुफ्त, उन्नत कार्य पर्याप्त मुफ्त परीक्षण प्रदान करते हैं, पारदर्शी और उचित पैकेज मूल्य, कोई छिपी हुई लागत नहीं।","seo_privacy_title":"गोपनीयता और सुरक्षा","seo_privacy_detail":"हम लक्षित विज्ञापन या डेटा पुनर्विक्रय के लिए उपयोगकर्ता फ़ोटो, डिवाइस जानकारी, या जियोलोकेशन एकत्र नहीं करते हैं। संपादित छवियां 3 दिनों (लॉग इन उपयोगकर्ताओं के लिए 30 दिन) के बाद स्वचालित रूप से साफ़ हो जाती हैं।","seo_commercial_title":"निःशुल्क व्यावसायिक उपयोग","seo_commercial_detail":"प्लेटफ़ॉर्म द्वारा वितरित सभी फ़ॉन्ट और उत्पादित कोई भी सामग्री व्यावसायिक उपयोग के लिए निःशुल्क है, बिना किसी कॉपीराइट चिंता के।","works_on_web_and_mobile":"वेब और मोबाइल पर काम करता है","works_on_web_and_mobile_detail":"आप कहीं भी और कभी भी अपने मोबाइल फोन के माध्यम से हमारी साइट पर पहुंच सकते हैं।","faq":"अक्सर पूछे जाने वाले प्रश्न","recommended_articles":"अनुशंसित लेख","example":"उदाहरण","image_text_editor":"छवि पाठ संपादक","not_browser_language":"वर्तमान भाषा ब्राउज़र की भाषा नहीं है।","features":"सुविधाएँ","user_agreement":"उपयोगकर्ता समझौता","privacy_policy":"गोपनीयता नीति","frequently_asked_questions":"सामान्य प्रश्न","contact_support":"सहायता से संपर्क करें","help":"सहायता","parameter_access_and_embed":"पैरामीटर एक्सेस/एम्बेड"},"editor":{"mark_tool":"चिह्नित उपकरण","mark_tool_tooltip":"आप AI को यह बताने के लिए क्षेत्रों को चिह्नित कर सकते हैं कि क्या संशोधित करना है, जैसे \'लाल क्षेत्र में सामग्री हटाएं\'","open":"खोलें","close":"बंद करें","meta":{"title":"स्क्रीनशॉट पाठ संपादक, छवि पाठ संपादक - PhoText","description":"PhoText आपके लिए स्क्रीनशॉट में पाठ को संशोधित करना आसान बनाता है, बिना फोटो संपादन कौशल सीखने की आवश्यकता के, भारी सॉफ़्टवेयर पर निर्भरता से मुक्त करता है, और आपको अपने स्क्रीनशॉट में स्टाम्प/हस्ताक्षर/वॉटरमार्क जोड़ने की भी अनुमति देता है।","keywords":"स्क्रीनशॉट में पाठ संपादित करें, स्क्रीनशॉट पाठ संपादक, स्क्रीनशॉट में पाठ ठीक करें, स्क्रीनशॉट में पाठ बदलें, स्क्रीनशॉट में पाठ प्रतिस्थापित करें"},"title":"चित्र टेक्स्ट संपादक","description":"चित्रों में टेक्स्ट को सबसे सरल और तेज़ तरीके से संपादित करें। AI की मदद से चित्रों में टेक्स्ट को आसानी से बदलें। चित्र के टेक्स्ट पर क्लिक करें और उसे संपादित करें, बिना किसी संपादन कौशल या सॉफ़्टवेयर की आवश्यकता के।","effect":"प्रभाव","stamp":"हस्ताक्षर","removement":"हटाना","removements":"हटाने के प्रभाव","information":"जानकारी","wordart":"शब्द कला","none":"कोई नहीं","gray":"ग्रे स्केल","saturation":"संतृप्ति","black_white":"काला/सफेद","light":"चमक","noise":"शोर","mosaic":"मोज़ेक","blur":"धुंधला","spread":"फैलाना","sharpen":"तेज करें","choose_image":"अपलोड करें","reset":"रीसेट करें","export":"निर्यात करें","add":"जोड़ें","itext_placeholder_or":"पाठ पर क्लिक करें या","itext_placeholder":"पाठ पर क्लिक करें","itext_placeholder_ai":"पाठ बॉक्स नए पाठ के साथ पुनः रेखांकित होगा","font":"फॉन्ट","preset":"प्रीसेट","save_preset":"प्रीसेट सहेजें","enter_preset_name":"कृपया प्रीसेट नाम दर्ज करें","erase_image":"मूल पाठ","style":"शैली","position":"स्थिति","transform":"रूपांतरण","prompt":"प्रांप्ट","no_text_selected":"कोई पाठ चयनित नहीं","download":"डाउनलोड करें","color":"रंग","color_fill":"रंग भरना","BG_color":"BG रंग","size":"आकार","weight":"वजन","stroke":"स्ट्रोक","span":"स्पेसिंग","opacity":"अपारदर्शिता","rotation":"घुमाव","bold":"बोल्ड","italic":"इटैलिक","underline":"अंडरलाइन","through":"क्रॉसआउट","adjust_params":"पैरामीटर","input_value":"मान दर्ज करें","range":"सीमा: {{min}} ~ {{max}}","loading":"लोड हो रहा है","processing":"प्रसंस्करण","model_downloading":"लोड हो रहा है","ai_generating":"जनरेट हो रहा है...","slow_generating":"जनरेट हो रहा है... लगभग 1 मिनट लग सकता है","recognize_text":"पाठ पहचानें","upload_font":"फॉन्ट अपलोड करें","click_to_generate":"जनरेट करें","lon