,p=a(2265),h=a(92468),f=a(82005),g=a(96374),v=a(98612),b=a(4563),y=a(62177),j=a(74389),w=a(8430),N=a(74853),k=a(48877),Z=a(47198),C=a(83588),_=a(43949),S=a(36760),D=a.n(S),P=a(64654),I=a(15789),F=a(71031),E=a(34766),T=a(94437),z=a(97632),R=a(88639),A=a(96207),M=a(15273),B=a(35389),W=a(58414),L=a(73261),O=a(6228),G=a(67116),q=a(67051),U=a(8633),H=a(38723),X=a(71174),Y=a(88894),$=a(9060),V=()=>{let e=(0,$.J)();return(0,n.jsx)(X.Z,{content:{en:'# AI Image Editing Guide\n  \n  ## \uD83C\uDFA8 I specialize in the following image editing tasks:\n  - **Text Editing**: Replace text in signs, posters, and labels\n  - **Style Transfer**: Convert photos to art styles (watercolor, oil painting, sketch)\n  - **Object/Clothing Changes**: Modify hairstyles, add accessories, change colors\n  - **Background Swapping**: Change environments while preserving subjects\n  - **Character Consistency**: Maintain identity across multiple edits\n  \n  ## \uD83D\uDCA1 How to get better results:\n  \n  #### \uD83D\uDD20 Text Editing Tips\n  - Use quotes:  \n    `Replace "123" with "456"`\n  - Point directly to original text, avoid pronoun ambiguity:\n    `Change the title to "Welcome"`: ❌ Ambiguous, unclear if "title" refers to the text "title" in the image or which text\'s title\n  - Match text length when possible\n  \n  #### ✏️ Be Specific\n  - Use detailed descriptions:  \n    `Example: "the woman with short black hair" not "she"`\n  - Avoid vague terms like "make it better"\n  - Name subjects directly\n  - Avoid referencing previous content - each request should be independent\n\n  #### \uD83D\uDCBE Preserve Intentionally\n  - Specify what to keep:  \n    `"while keeping the same facial features"`\n  - Use "maintain original composition"\n  - For backgrounds:  \n    `"Change background to beach while keeping person in same position"`\n  \n  #### \uD83D\uDD8C️ Style Transfer\n  - Name specific styles:  \n    `"impressionist painting" not "artistic"`\n  - Reference art movements:  \n    `"Renaissance" or "1960s pop art"`\n  - Describe textures:  \n    `"visible brushstrokes, thick paint"`\n  \n  #### \uD83E\uDDE9 Complex Edits\n  - Break into smaller steps\n  - Start simple and iterate\n  - Use action verbs:  \n    `"widen", "brighten" not "transform"`\n  \n  ',cn:'# AI改图指南   \n    \n  ## \uD83C\uDFA8 我擅长处理以下图片任务:\n  - **文本编辑**：如替换标志、海报和标签中的文字\n  - **风格转换**：将照片转换为不同的艺术风格（水彩画、油画、素描等）\n  - **物体/服装变化**：修改发型、添加配饰、改变颜色等\n  - **背景交换**：在保留主题的同时改变环境\n  - **角色一致性**：在多次编辑中保持原角色\n  \n  ## \uD83D\uDCA1 提升效果的技巧:\n  \n  #### \uD83D\uDD20 文字编辑技巧\n  - 使用引号标记：  \n    `把文字"123"替换为"456"` ✅\n  - 直接指向原文字，避免代词产生歧义:\n    `把标题改为"欢迎光临"`: ❌ 存在歧义，不确定标题指的是图中的文字"标题"还是指代哪个文字的标题\n  - 尽可能匹配文本长度以保留布局\n  \n  #### ✏️ 具体一点\n  - 使用清晰、详细的语言以及准确的颜色和描述  \n    `示例："留着黑色短发的女人" 而不是 "她"`\n  - 避免使用"使其变得更好"等模糊的术语\n  - 直接说出主题\n  - 避免引用之前的内容，每一次对话都是独立的\n  \n  #### \uD83D\uDCBE 指定保留\n  - 指定哪些部分应该保持不变：  \n    `"同时保持相同的面部特征"`\n  - 使用"保持原始构图"来保留布局\n  - 对于背景变化：  \n    `"将背景更改为海滩，同时保持人物处于完全相同的位置"`\n  \n  #### \uD83D\uDD8C️ 风格转换\n  - 明确艺术风格：  \n    `"印象派绘画" 而不是 "艺术"`\n  - 参考知名运动：  \n    `"文艺复兴" 或 "20世纪60年代波普艺术"`\n  - 描述关键特征：  \n    `"清晰可见的笔触、厚实的颜料质感"`\n  \n  #### \uD83E\uDDE9 复杂编辑\n  - 分解成更小的步骤以获得更好的结果\n  - 从简单开始并不断迭代\n  - 使用描述性动作动词：  \n    `"加宽"、"调亮" 而不是 "转变"`\n  \n  ',jp:'# AI画像編集ガイド\n  \n  ## \uD83C\uDFA8 以下の画像編集タスクを専門としています:\n  - **テキスト編集**: 看板やポスターの文字変更\n  - **スタイル変換**: 水彩画、油絵、スケッチなどへの変換\n  - **オブジェクト/服装変更**: 髪型、アクセサリー、色変更\n  - **背景変更**: 被写体を維持した環境変更\n  - **キャラクター一貫性**: 複数編集での同一性保持\n  \n  ## \uD83D\uDCA1 効果的な指示方法:\n  \n  #### \uD83D\uDD20 テキスト編集\n  - 引用符使用:  \n    `"123"を"456"に変更`\n  - 元のテキストを直接指定し、代名詞による曖昧さを避ける:\n    `タイトルを「ようこそ」に変更`: ❌ 曖昧、「タイトル」が画像内の「タイトル」という文字を指すのか、どの文字のタイトルを指すのか不明\n  - 文字数は可能な限り一致\n  \n  #### ✏️ 具体的に\n  - 詳細な説明:  \n    `例: "黒いショートヘアの女性" ではなく "彼女"`\n  - "改善する"等の曖昧な表現は避ける\n  \n  #### \uD83D\uDCBE 保持指定\n  - 維持要素の明示:  \n    `"顔の特徴はそのままに"`\n  - "元の構図を維持"でレイアウト保持\n  \n  #### \uD83D\uDD8C️ スタイル変換\n  - 特定のスタイル名:  \n    `"印象派" ではなく "芸術的"`\n  - 美術運動の参照:  \n    `"ルネサンス" 或 "1960年代ポップアート"`\n  \n  #### \uD83E\uDDE9 複雑編集\n  - 小ステップに分割\n  - シンプルに開始し反復\n  - 動作動詞使用:  \n    `"広くする"、"明るくする"`\n  \n  ',es:'# Gu\xeda de Edici\xf3n de Im\xe1genes con IA\n\n  ## \uD83C\uDFA8 Me especializo en las siguientes tareas de edici\xf3n de im\xe1genes::\n  - **Edici\xf3n de texto**: Modificar letreros, carteles o etiquetas\n  - **Cambio de estilo**: Convertir a acuarela, \xf3leo o boceto\n  - **Modificar objetos**: Cambiar peinados, a\xf1adir accesorios o ajustar colores\n  - **Fondos**: Alterar el entorno manteniendo al sujeto principal\n  - **Consistencia**: Preservar la identidad en m\xfaltiples ediciones\n  \n  ## \uD83D\uDCA1 Para mejores resultados:\n  \n  #### \uD83D\uDD20 Edici\xf3n de texto\n  - Usa comillas:  \n    `Cambiar "2024" por "2025"`\n  - Apunta directamente al texto original, evita ambig\xfcedad de pronombres:\n    `Cambiar el t\xedtulo a "Bienvenido"`: ❌ Ambiguo, no est\xe1 claro si "t\xedtulo" se refiere al texto "t\xedtulo" en la imagen o al t\xedtulo de qu\xe9 texto\n  - Mant\xe9n la longitud similar para conservar el dise\xf1o\n  \n  #### ✏️ S\xe9 espec\xedfico\n  - Ejemplo claro:  \n    `"la mujer de pelo corto negro" no "ella"`\n  - Evita t\xe9rminos vagos como "mej\xf3ralo"\n  - Nombra los elementos directamente\n  \n  #### \uD83D\uDCBE Conserva elementos\n  - Especifica qu\xe9 mantener:  \n    `"conservando los rasgos faciales"`\n  - Usa "mantener la composici\xf3n original"\n  - Para fondos:  \n    `"Cambiar a playa conservando la posici\xf3n exacta"`\n  \n  #### \uD83D\uDD8C️ Cambio de estilo\n  - Nombra estilos concretos:  \n    `"pintura impresionista" no "art\xedstico"`\n  - Refiere movimientos:  \n    `"Renacimiento" o "arte pop de los 60s"`\n  - Describe texturas:  \n    `"pinceladas visibles, pigmento grueso"`\n  \n  #### \uD83E\uDDE9 Ediciones complejas\n  - Divide en pasos peque\xf1os\n  - Comienza con cambios simples\n  - Usa verbos de acci\xf3n:  \n    `"ensanchar", "iluminar" no "transformar"`\n  \n  ',fr:'# Guide de retouche d\'images par IA\n\n## \uD83C\uDFA8 Je me sp\xe9cialise dans les t\xe2ches de retouche d\'image suivantes :\n- **\xc9dition de texte** : Modifier panneaux, affiches ou \xe9tiquettes\n- **Changement de style** : Conversion aquarelle, peinture \xe0 l\'huile ou croquis\n- **Modification d\'objets** : Coiffures, accessoires ou changements de couleur\n- **Arri\xe8re-plans** : Changer l\'environnement en conservant le sujet\n- **Coh\xe9rence** : Maintenir l\'identit\xe9 sur plusieurs modifications\n\n## \uD83D\uDCA1 Pour des r\xe9sultats optimaux :\n\n#### \uD83D\uDD20 \xc9dition de texte\n- Utilisez des guillemets :  \n  `Remplacer "2024" par "2025"`\n- Pointez directement vers le texte original, \xe9vitez l\'ambigu\xeft\xe9 des pronoms :\n  `Changer le titre en "Bienvenue"` : ❌ Ambigu, pas clair si "titre" fait r\xe9f\xe9rence au texte "titre" dans l\'image ou au titre de quel texte\n- Conservez la longueur du texte pour le layout\n\n#### ✏️ Soyez pr\xe9cis\n- Exemple clair :  \n  `"la femme aux cheveux courts noirs" pas "elle"`\n- \xc9vitez "am\xe9liorez \xe7a"\n\n#### \uD83D\uDCBE Pr\xe9servation cibl\xe9e\n- Sp\xe9cifiez les \xe9l\xe9ments \xe0 conserver :  \n  `"tout en gardant les traits du visage"`\n- Utilisez "conserver la composition originale"\n- Pour les arri\xe8re-plans :  \n  `"Changer en plage en gardant la position exacte"`\n\n#### \uD83D\uDD8C️ Changement de style\n- Nommez les styles :  \n  `"peinture impressionniste" pas "artistique"`\n- R\xe9f\xe9rez les mouvements :  \n  `"Renaissance" ou "pop art des ann\xe9es 60"`\n- D\xe9crivez les textures :  \n  `"coups de pinceau visibles, peinture \xe9paisse"`\n\n#### \uD83E\uDDE9 Modifications complexes\n- Divisez en \xe9tapes\n- Commencez simplement\n- Utilisez des verbes d\'action :  \n  `"\xe9largir", "\xe9claircir" pas "transformer"`\n\n',hi:'# AI इमेज संपादन गाइड\n\n## \uD83C\uDFA8 मैं निम्नलिखित छवि संपादन कार्यों में विशेषज्ञ हूँ:\n- **पाठ संपादन**: साइनबोर्ड, पोस्टर या लेबल में टेक्स्ट बदलना\n- **शैली परिवर्तन**: वॉटरकलर, ऑयल पेंटिंग या स्केच में बदलाव\n- **वस्तु/कपड़े बदलाव**: हेयरस्टाइल, एक्सेसरीज या रंग बदलना\n- **बैकग्राउंड बदलाव**: मुख्य विषय को बनाए रखते हुए वातावरण बदलना\n- **चरित्र स्थिरता**: कई संपादनों में पहचान बनाए रखना\n\n## \uD83D\uDCA1 बेहतर परिणाम के लिए:\n\n#### \uD83D\uDD20 पाठ संपादन युक्तियाँ\n- उद्धरण चिह्न प्रयोग करें:  \n  `"2024" को "2025" से बदलें`\n- मूल पाठ को सीधे इंगित करें, सर्वनाम की अस्पष्टता से बचें:\n  `शीर्षक को "स्वागत" में बदलें`: ❌ अस्पष्ट, यह स्पष्ट नहीं है कि "शीर्षक" छवि में "शीर्षक" पाठ को संदर्भित करता है या किस पाठ के शीर्षक को\n- टेक्स्ट लंबाई समान रखने का प्रयास करें\n\n#### ✏️ विस्तृत निर्देश\n- स्पष्ट उदाहरण:  \n  `"छोटे काले बालों वाली महिला" न कि "वह"`\n- "इसे बेहतर बनाओं" जैसे अस्पष्ट शब्दों से बचें\n- सीधे विषय का नाम लें\n\n#### \uD83D\uDCBE संरक्षण निर्देश\n- क्या बनाए रखना है बताएँ:  \n  `"चेहरे की विशेषताएँ समान रखते हुए"`\n- "मूल कंपोजिशन बनाए रखें" प्रयोग करें\n- बैकग्राउंड बदलाव के लिए:  \n  `"व्यक्ति की स्थिति समान रखते हुए बैकग्राउंड बीच में बदलें"`\n\n#### \uD83D\uDD8C️ शैली परिवर्तन\n- विशिष्ट शैलियाँ बताएँ:  \n  `"इंप्रेशनिस्ट पेंटिंग" न कि "कलात्मक"`\n- कला शैलियों का उल्लेख करें:  \n  `"रेनैस्सेंस" या "1960s पॉप आर्ट"`\n- विशेषताएँ बताएँ:  \n  `"दिखाई देने वाली ब्रशस्ट्रोक्स, गाढ़ा पेंट"`\n\n#### \uD83E\uDDE9 जटिल संपादन\n- छोटे चरणों में बाँटें\n- सरलता से शुरू करें\n- क्रिया शब्दों का प्रयोग करें:  \n  `"चौड़ा करें", "हल्का करें" न कि "बदल दें"`\n\n',ko:'# AI 이미지 편집 가이드\n\n## \uD83C\uDFA8 다음과 같은 이미지 편집 작업을 전문으로 합니다:\n- **텍스트 편집**: 간판, 포스터, 라벨의 문자 수정\n- **스타일 변환**: 수채화, 유화, 스케치 효과\n- **객체/의류 변경**: 헤어스타일, 액세서리, 색상 변경\n- **배경 변경**: 피사체 유지하며 환경 변경\n- **캐릭터 일관성**: 여러 편집에서 동일성 유지\n\n## \uD83D\uDCA1 더 나은 결과를 위한 팁:\n\n#### \uD83D\uDD20 텍스트 편집 요령\n- 따옴표 사용:  \n  `"2024"를 "2025"로 변경`\n- 원본 텍스트를 직접 지정하여 대명사 모호성 방지:\n  `제목을 "환영합니다"로 변경`: ❌ 모호함, "제목"이 이미지의 "제목" 텍스트를 가리키는지 어떤 텍스트의 제목을 가리키는지 불분명\n- 텍스트 길이는 가능한 유지\n\n#### ✏️ 구체적으로 작성\n- 명확한 예시:  \n  `"짧은 검은 머리의 여성"이 아닌 "그녀"`\n- "개선해줘" 등 모호한 표현 피하기\n- 직접 대상 명시\n\n#### \uD83D\uDCBE 보존 지정\n- 유지할 요소 명시:  \n  `"동일한 얼굴 특징 유지하면서"`\n- "원본 구성 유지" 사용\n- 배경 변경 시:  \n  `"인물 위치는 그대로 두고 배경을 해변으로 변경"`\n\n#### \uD83D\uDD8C️ 스타일 변환\n- 구체적 스타일 명시:  \n  `"인상주의 그림"이 아닌 "예술적"`\n- 예술 사조 언급:  \n  `"르네상스" 또는 "1960년대 팝아트"`\n- 특징 설명:  \n  `"붓터치 보임, 두꺼운 페인트"`\n\n#### \uD83E\uDDE9 복잡한 편집\n- 단계별로 분할\n- 간단하게 시작해 점진적 개선\n- 동사 사용:  \n  `"넓힌다", "밝게 한다"이 아닌 "변환한다"`\n\n',pt:'# Guia de Edi\xe7\xe3o de Imagens com IA\n\n## \uD83C\uDFA8 Eu me especializo nas seguintes tarefas de edi\xe7\xe3o de imagens:\n- **Edi\xe7\xe3o de texto**: Modificar placas, cartazes ou etiquetas\n- **Transfer\xeancia de estilo**: Converter para aquarela, pintura a \xf3leo ou esbo\xe7o\n- **Altera\xe7\xe3o de objetos**: Mudar penteados, acess\xf3rios ou cores\n- **Troca de fundo**: Alterar ambiente mantendo o assunto principal\n- **Consist\xeancia**: Manter identidade em m\xfaltiplas edi\xe7\xf5es\n\n## \uD83D\uDCA1 Como obter melhores resultados:\n\n#### \uD83D\uDD20 Dicas para edi\xe7\xe3o de texto\n- Use aspas:  \n  `Substitua "2024" por "2025"`\n- Aponte diretamente para o texto original, evite ambiguidade de pronomes:\n  `Mude o t\xedtulo para "Bem-vindo"`: ❌ Amb\xedguo, n\xe3o est\xe1 claro se "t\xedtulo" se refere ao texto "t\xedtulo" na imagem ou ao t\xedtulo de qual texto\n- Mantenha o comprimento do texto similar\n\n#### ✏️ Seja espec\xedfico\n- Exemplo claro:  \n  `"a mulher de cabelo curto preto" n\xe3o "ela"`\n- Evite termos vagos como "melhore isso"\n- Nomeie os elementos diretamente\n\n#### \uD83D\uDCBE Preserva\xe7\xe3o intencional\n- Especifique o que manter:  \n  `"mantendo as mesmas caracter\xedsticas faciais"`\n- Use "manter a composi\xe7\xe3o original"\n- Para fundos:  \n  `"Mude o fundo para praia mantendo a posi\xe7\xe3o exata"`\n\n#### \uD83D\uDD8C️ Transfer\xeancia de estilo\n- Nomeie estilos espec\xedficos:  \n  `"pintura impressionista" n\xe3o "art\xedstico"`\n- Referencie movimentos:  \n  `"Renascimento" ou "pop art dos anos 60"`\n- Descreva texturas:  \n  `"pinceladas vis\xedveis, tinta espessa"`\n\n#### \uD83E\uDDE9 Edi\xe7\xf5es complexas\n- Divida em etapas menores\n- Comece simples e itere\n- Use verbos de a\xe7\xe3o:  \n  `"alargar", "clarear" n\xe3o "transformar"`\n\n',ru:'# Руководство по редактированию изображений с ИИ\n\n## \uD83C\uDFA8 Я специализируюсь на следующих задачах редактирования изображений:\n- **Редактирование текста**: Изменение надписей на вывесках, плакатах или этикетках\n- **Смена стиля**: Преобразование в акварель, масляную живопись или эскиз\n- **Изменение объектов**: Прически, аксессуары или цвета\n- **Замена фона**: Изменение окружения с сохранением основного объекта\n- **Сохранение идентичности**: Поддержка единого стиля при множественных правках\n\n## \uD83D\uDCA1 Как добиться лучших результатов:\n\n#### \uD83D\uDD20 Работа с текстом\n- Используйте кавычки:  \n`Замените "2024" на "2025"`\n- Указывайте прямо на исходный текст, избегайте неоднозначности местоимений:\n`Измените заголовок на "Добро пожаловать"`: ❌ Неоднозначно, неясно, относится ли "заголовок" к тексту "заголовок" на изображении или к заголовку какого текста\n- Сохраняйте длину текста\n\n#### ✏️ Будьте конкретны\n- Четкий пример:  \n`"женщина с короткими черными волосами" а не "она"`\n- Избегайте расплывчатых формулировок типа "сделай лучше"\n- Называйте элементы напрямую\n\n#### \uD83D\uDCBE Сохранение элементов\n- Указывайте что оставить:  \n`"сохраняя черты лица"`\n- Используйте "сохранить оригинальную композицию"\n- Для фона:  \n`"Замените фон на пляж, сохранив точное положение"`\n\n#### \uD83D\uDD8C️ Смена стиля\n- Указывайте конкретные стили:  \n`"импрессионизм" а не "художественный"`\n- Ссылайтесь на направления:  \n`"Ренессанс" или "поп-арт 60-х"`\n- Описывайте детали:  \n`"видимые мазки кисти, густая краска"`\n\n#### \uD83E\uDDE9 Сложные правки\n- Разбивайте на этапы\n- Начинайте с простого\n- Используйте глаголы действий:  \n`"расширить", "осветлить" а не "трансформировать"`\n\n',th:'# คู่มือการแก้ไขภาพด้วย AI\n\n## \uD83C\uDFA8 ฉันมีความเชี่ยวชาญในงานแก้ไขภาพต่อไปนี้:\n- **แก้ไขข้อความ**: เปลี่ยนข้อความบนป้าย โปสเตอร์ หรือฉลาก\n- **เปลี่ยนสไตล์**: แปลงเป็นภาพวาดสีน้ำ ภาพสีน้ำมัน หรือภาพสเก็ตช์\n- **เปลี่ยนวัตถุ/เสื้อผ้า**: ทรงผม เครื่องประดับ หรือสี\n- **เปลี่ยนพื้นหลัง**: เปลี่ยนสภาพแวดล้อมโดยคงวัตถุหลักไว้\n- **ความสม่ำเสมอ**: รักษาความเป็นตัวตนในการแก้ไขหลายครั้ง\n\n## \uD83D\uDCA1 วิธีใช้งานให้ได้ผลลัพธ์ดีที่สุด:\n\n#### \uD83D\uDD20 เคล็ดลับการแก้ไขข้อความ\n- ใช้เครื่องหมายคำพูด:  \n  `เปลี่ยน "2024" เป็น "2025"`\n- ชี้ไปที่ข้อความต้นฉบับโดยตรง หลีกเลี่ยงความคลุมเครือของสรรพนาม:\n  `เปลี่ยนหัวข้อเป็น "ยินดีต้อนรับ"`: ❌ คลุมเครือ ไม่ชัดเจนว่า "หัวข้อ" หมายถึงข้อความ "หัวข้อ" ในภาพหรือหัวข้อของข้อความใด\n- พยายามให้ความยาวข้อความใกล้เคียงเดิม\n\n#### ✏️ ระบุรายละเอียด\n- ตัวอย่างที่ชัดเจน:  \n  `"ผู้หญิงผมสั้นสีดำ" ไม่ใช่ "เธอ"`\n- หลีกเลี่ยงคำกำกวมเช่น "ทำให้ดีขึ้น"\n- เรียกชื่อวัตถุโดยตรง\n\n#### \uD83D\uDCBE การคงองค์ประกอบ\n- ระบุสิ่งที่ต้องการคงไว้:  \n  `"รักษาลักษณะใบหน้าเดิม"`\n- ใช้ "รักษาการจัดวางองค์ประกอบเดิม"\n- สำหรับพื้นหลัง:  \n  `"เปลี่ยนพื้นหลังเป็นทะเลโดยรักษาตำแหน่งเดิม"`\n\n#### \uD83D\uDD8C️ การเปลี่ยนสไตล์\n- ระบุสไตล์เฉพาะ:  \n  `"ภาพวาดอิมเพรสชันนิสม์" ไม่ใช่ "ศิลปะ"`\n- อ้างอิงยุคสมัย:  \n  `"เรอเนสซองส์" หรือ "ป็อปอาร์ตยุค 60"`\n- อธิบายลักษณะ:  \n  `"เห็นรอยแปรง, สีหนา"`\n\n#### \uD83E\uDDE9 การแก้ไขที่ซับซ้อน\n- แบ่งเป็นขั้นตอนย่อย\n- เริ่มจากสิ่งที่ง่ายก่อน\n- ใช้คำกริยาเชิงปฏิบัติการ:  \n  `"ขยาย", "ทำให้สว่าง" ไม่ใช่ "แปลง"`\n\n',hant:"# AI 修圖指南\n\n## \uD83C\uDFA8 我的專長：\n- **文字編輯**：修改標誌、海報或標籤中的文字\n- **風格轉換**：轉換為水彩、油畫或素描等藝術風格\n- **物件/服裝修改**：改變髮型、配件或顏色\n- **背景替換**：更換環境同時保留主體\n- **角色一致性**：在多個編輯中保持角色特徵\n\n## \uD83D\uDCA1 提升效果的小技巧：\n\n#### \uD83D\uDD20 文字編輯要點\n- 使用引號標記：  \n`將「2024」改為「2025」`\n- 直接指向原文字，避免代詞產生歧義：\n`把標題改為「歡迎光臨」`：❌ 存在歧義，不確定標題指的是圖中的文字「標題」還是指代哪個文字的標題\n- 盡量保持文字長度相近\n\n#### ✏️ 具體明確\n- 清晰範例：  \n`「黑色短髮女性」而非「她」`\n- 避免「讓它更好」等模糊用語\n- 直接指明修改目標\n\n#### \uD83D\uDCBE 指定保留內容\n- 明確需保留部分：  \n`「同時保持相同面部特徵」`\n- 使用「保持原始構圖」\n- 背景修改時：  \n`「將背景改為海灘，同時讓人維持完全相同的位置」`\n\n#### \uD83D\uDD8C️ 風格轉換\n- 指定具體風格：  \n`「印象派畫風」而非「藝術風格」`\n- 參考知名流派：  \n`「文藝復興」或「1960年代普普藝術」`\n- 描述關鍵特徵：  \n`「明顯筆觸、厚重顏料質感」`\n\n#### \uD83E\uDDE9 複雜編輯\n- 拆解為多個步驟\n- 從簡單修改開始\n- 使用具體動詞：  \n`「加寬」、「調亮」而非「轉換」`\n\n"}[e]})},K=a(88506),J=a(30662),Q=a(52507),ee=a(97048),et=(0,Z.Pi)(e=>{let{className:t}=e,[a]=(0,_.$G)();(0,H.G)();let l=(0,Y.L)(),s=(0,C.N4)(),o=z.Z.messages.filter(e=>e.img).map(e=>({id:e.id,url:(0,U.qm)(e.img)})),d=o.map(e=>e.url);return(0,n.jsx)(c.Z,{className:D()(t),sx:{display:"flex",flexDirection:"column"},children:(0,n.jsx)(A.Z,{sx:{flex:1,background:"transparent"},elevation:0,children:(0,n.jsxs)(M.Z,{dense:!0,children:[0===z.Z.messages.length&&(0,n.jsx)("div",{className:"w-full flex items-center justify-center h-32 !opacity-70",children:(0,n.jsx)(B.Z,{className:"opacity-70 mt-2 !w-5 !h-5"})}),z.Z.messages.map(e=>{let t="other"===e.sender?"fast"===e.mode?"#f0faf2":"advanced"===e.mode?"#f3f3fe":"white":"rgb(149 236 105)",u=e.img?(0,U.qm)(e.img):void 0,m=u?o.findIndex(t=>t.id===e.id):-1;return(0,n.jsx)(W.Z,{direction:"up",in:!0,mountOnEnter:!0,unmountOnExit:!0,children:(0,n.jsxs)(L.ZP,{sx:{justifyContent:"user"===e.sender?"flex-end":"flex-start",alignItems:"stretch",flexWrap:"wrap",py:.5,px:1,mt:1},children:["other"===e.sender&&(0,n.jsx)(O.Z,{sx:{minWidth:0,mr:1.5},children:(0,n.jsx)(G.Z,{sx:{bgcolor:"primary.main",width:32,height:32},children:(0,n.jsx)("img",{src:"/img/photext-logo-128.png",alt:"logo",title:"logo"})})}),"user"===e.sender&&e.loading&&(0,n.jsx)(B.Z,{className:"!w-4 !h-4 mr-2 !mt-3.5 opacity-30"}),"user"===e.sender&&(0,n.jsx)("div",{className:"flex-grow"}),(0,n.jsxs)(A.Z,{sx:{p:1,py:1,borderRadius:2,position:"relative",overflow:"visible",backgroundColor:t,maxWidth:"74%",width:"other"===e.sender?"74%":void 0,whiteSpace:"pre-wrap","&::before":{content:'""',position:"absolute",top:12,width:10,height:10,backgroundColor:t,transform:"rotate(45deg)",borderStyle:"solid",borderWidth:"1px",borderColor:"other"===e.sender?"#e0e7ff":"#e2e8f0",..."oth